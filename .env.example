# Server runtime (must match deploy/runtime.cjs; production always 3001)
PORT=3001
HOSTNAME=0.0.0.0
NODE_ENV=production

# Public site URL (used for metadata, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://darulquran.pk

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# On-demand revalidation (Sanity webhook → POST /api/revalidate?secret=...)
REVALIDATE_SECRET=

# Contact notifications — prefer Resend
RESEND_API_KEY=
EMAIL_FROM=contact@darulquran.pk
EMAIL_TO=

# Legacy Gmail SMTP fallback (if RESEND_API_KEY unset)
EMAIL_USER=
EMAIL_PASS=

# Rate limiting (optional — uses in-memory limit on single VPS if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (optional — skipped if unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
